def load_yaml(path):
    try:
        import yaml
        with open(path, "r") as fh:
            return yaml.safe_load(fh)
    except ImportError:
        return _basic_yaml_parse(path)
    except Exception:
        return None

def _basic_yaml_parse(path):
    data, current_key = {}, None
    try:
        with open(path, "r") as fh:
            for line in fh:
                s = line.strip()
                if not s or s.startswith("#"):
                    continue
                if ":" in s and not s.startswith("-"):
                    parts = s.split(":", 1)
                    k = parts[0].strip()
                    v = parts[1].strip() if len(parts) > 1 else ""
                    data[k] = v if v else {}
                    current_key = k
    except Exception:
        return None
    return data

def find_nemoclaw_root():
    candidates = [
        Path.cwd() / "nemoclaw-blueprint",
        Path.home() / ".nemoclaw",
        Path("/opt/nemoclaw/nemoclaw-blueprint"),
    ]
    npm_root = os.popen("npm root -g 2>/dev/null").read().strip()
    if npm_root:
        candidates.append(Path(npm_root) / "nemoclaw" / "nemoclaw-blueprint")
    for c in candidates:
        if c.exists():
            return c
    return None

def run_nemoclaw_checks(policy_path_arg=None):
    from pathlib import Path as _P
    nc_root   = find_nemoclaw_root()
    pol_path  = None
    if policy_path_arg:
        p = _P(policy_path_arg)
        pol_path = p if p.exists() else None
    elif nc_root:
        for candidate in [nc_root / "policies" / "openclaw-sandbox.yaml",
                          nc_root / "openclaw-sandbox.yaml"]:
            if candidate.exists():
                pol_path = candidate
                break
    pol_data = load_yaml(pol_path) if pol_path else None

    findings = []

    # NC01 policy exists
    f = Finding(1, "Network", "NC01", "Policy file exists", "CRITICAL", "",
                "Ensure openclaw-sandbox.yaml exists in nemoclaw-blueprint/policies/")
    if pol_path and pol_path.exists():
        f.passed = True
        f.detail = "Policy found at {}.".format(pol_path)
    else:
        f.detail = "No openclaw-sandbox.yaml found. NemoClaw has no active network policy."
    findings.append(f)

    # NC02 binary scoping
    f = Finding(1, "Network", "NC02", "Binary-scoped network policies", "HIGH", "",
                "Add 'binaries:' restrictions to every network policy entry. See NVIDIA/NemoClaw#272.")
    net = pol_data.get("network_policies", pol_data.get("network", {})) if pol_data else {}
    if isinstance(net, dict) and net:
        unscoped = [n for n, e in net.items() if isinstance(e, dict) and not e.get("binaries")]
        if not unscoped:
            f.passed = True
            f.detail = "All network policy entries have binary restrictions."
        else:
            f.detail = "Unscoped entries (any binary can use): {}.".format(", ".join(unscoped))
    else:
        f.detail = "No network_policies section in policy."
    findings.append(f)

    # NC03 wildcard endpoints
    f = Finding(1, "Network", "NC03", "No wildcard endpoints", "HIGH", "",
                "Replace wildcard endpoints with explicit host:port pairs.")
    wildcards = []
    if isinstance(net, dict):
        for name, entry in net.items():
            if isinstance(entry, dict):
                for ep in entry.get("endpoints", []):
                    host = ep.get("host", "") if isinstance(ep, dict) else str(ep)
                    if "*" in str(host) or "0.0.0.0" in str(host):
                        wildcards.append("{}: {}".format(name, host))
    if not wildcards:
        f.passed = True
        f.detail = "No wildcard endpoints found."
    else:
        f.detail = "Wildcard endpoints: {}.".format(", ".join(wildcards))
    findings.append(f)

    # NC04 TLS
    f = Finding(1, "Network", "NC04", "TLS enforcement", "MEDIUM", "",
                "All endpoints should use port 443 (TLS).")
    non_tls = []
    if isinstance(net, dict):
        for name, entry in net.items():
            if isinstance(entry, dict):
                for ep in entry.get("endpoints", []):
                    port = ep.get("port", 443) if isinstance(ep, dict) else 443
                    if port != 443:
                        non_tls.append("{}: port {}".format(name, port))
    if not non_tls:
        f.passed = True
        f.detail = "All endpoints use TLS."
    else:
        f.detail = "Non-TLS endpoints: {}.".format(", ".join(non_tls))
    findings.append(f)

    # NC08 Landlock (Linux only)
    if PLATFORM == "linux":
        f = Finding(4, "OS/Secrets", "NC08", "Landlock LSM", "HIGH", "",
                    "NemoClaw requires Linux 5.13+ with Landlock for filesystem isolation.")
        try:
            rel = platform.release().split(".")
            major, minor = int(rel[0]), int(rel[1]) if len(rel) > 1 else 0
            if major > 5 or (major == 5 and minor >= 13):
                lsm = Path("/sys/kernel/security/lsm")
                if lsm.exists() and "landlock" in lsm.read_text():
                    f.passed = True
                    f.detail = "Landlock LSM enabled (kernel {}.{}).".format(major, minor)
                else:
                    f.detail = "Kernel {}.{} supports Landlock but it is not enabled.".format(major, minor)
            else:
                f.detail = "Kernel {}.{} does not support Landlock (requires 5.13+).".format(major, minor)
        except Exception as e:
            f.detail = "Could not determine kernel version: {}.".format(e)
        findings.append(f)

    # NC10 inference costs
    f = Finding(5, "Financial", "NC10", "Inference cost controls", "MEDIUM", "",
                "Set up local Ollama fallback. Monitor usage at build.nvidia.com.")
    f.detail = "NemoClaw has no native spending limits. All inference uses NVIDIA cloud API."
    findings.append(f)

    # NC11 local inference
    f = Finding(5, "Financial", "NC11", "Local inference fallback", "LOW", "",
                "Configure Ollama or vLLM as inference fallback to reduce cloud costs.")
    local_llms = detect_local_llm()
    if local_llms:
        f.passed = True
        f.detail = "Local LLM detected: {}.".format(", ".join("{} ({})".format(n, d) for n, d in local_llms))
    else:
        f.detail = "No local LLM provider detected. All inference burns cloud API budget."
    findings.append(f)

    # NC16 LAN exposure
    findings.append(oc_check_lan_exposure())
    findings[-1].check_id = "NC16"

    # NC17 audit logs
    findings.append(oc_check_audit_logs())
    findings[-1].check_id = "NC17"

    return findings

# ---------------------------------------------------------------------------
# Scoring
# ---------------------------------------------------------------------------

SEVERITY_WEIGHTS = {"CRITICAL": 15, "HIGH": 10, "MEDIUM": 5, "LOW": 2, "INFO": 0}

def compute_score(findings):
    max_s  = sum(SEVERITY_WEIGHTS.get(f.severity, 0) for f in findings)
    if max_s == 0:
        return 100
    lost   = sum(SEVERITY_WEIGHTS.get(f.severity, 0) for f in findings if not f.passed)
    return max(0, min(100, int(((max_s - lost) / max_s) * 100)))

def grade(score):
    if score >= 90: return "Hardened"
    if score >= 70: return "Progressing"
    if score >= 50: return "Baseline"
    if score >= 25: return "Weak"
    return "Critical"

def score_bar(score):
    filled = int(score / 5)
    empty  = 20 - filled
    bar    = chr(0x2588) * filled + chr(0x2591) * empty
    color  = C["GREEN"] if score >= 70 else C["YELLOW"] if score >= 40 else C["RED"]
    return "{}{}{}".format(color, bar, C["RESET"])

