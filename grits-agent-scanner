def oc_check_plaintext_keys(config_path, config):
    """OC11: No plaintext API keys in config."""
    f = Finding(4, "OS/Secrets", "OC11", "Plaintext API keys", "CRITICAL", "",
                "Move API keys to environment variables or a secrets manager. "
                "See score/configs/install-guide.md for setup instructions.")
    if config_path is None:
        f.detail = "No config file found."
        return f
    try:
        raw = Path(config_path).read_text()
    except Exception:
        f.detail = "Could not read config file."
        return f
    key_patterns = [
        r'["\']?(?:api[_-]?key|apikey|secret|token|password)["\']?\s*[:=]\s*["\']?(?:sk-|xoxb-|xoxp-|ghp_|gho_|glpat-|AIZA)[A-Za-z0-9_\-]{10,}',
        r'["\']?(?:ANTHROPIC_API_KEY|OPENAI_API_KEY|SLACK_TOKEN|DISCORD_TOKEN|TELEGRAM_TOKEN)["\']?\s*[:=]\s*["\']?[A-Za-z0-9_\-]{10,}',
    ]
    found = []
    for pat in key_patterns:
        found.extend(re.findall(pat, raw, re.IGNORECASE))
    generic = re.findall(
        r'["\']?(?:key|secret|token|credential|password)["\']?\s*[:=]\s*["\']([A-Za-z0-9_\-]{20,})["\']',
        raw, re.IGNORECASE)
    found.extend(generic)
    if not found:
        f.passed = True
        f.detail = "No plaintext API keys detected in config."
    else:
        f.detail = "{} potential plaintext key(s) found in config file.".format(len(found))
    return f

def oc_check_env_perms():
    """OC12: .env file permissions."""
    f = Finding(4, "OS/Secrets", "OC12", ".env permissions", "HIGH", "",
                "Run: sudo chown root:root .env && sudo chmod 600 .env "
                "(macOS: sudo chown root:wheel .env)")
    oc_dir = openclaw_dir()
    checked, issues = [], []
    for env_path in [oc_dir / ".env", oc_dir / "secrets.env", Path.cwd() / ".env"]:
        if env_path.exists():
            checked.append(str(env_path))
            perms = file_perms(env_path)
            uid   = file_owner(env_path)
            if perms and perms not in ("0o600", "0o400"):
                issues.append("{}: perms={} (need 600)".format(env_path.name, perms))
            if uid is not None and uid != 0:
                issues.append("{}: owned by uid {} (need root)".format(env_path.name, uid))
    if not checked:
        f.passed = True
        f.detail = "No .env files found (good if using env injection)."
    elif not issues:
        f.passed = True
        f.detail = "All .env files have restrictive permissions."
    else:
        f.detail = "; ".join(issues) + "."
    return f

def oc_check_creds_dir_perms():
    """OC13: Credentials directory permissions."""
    f = Finding(4, "OS/Secrets", "OC13", "Credentials dir permissions", "HIGH", "",
                "sudo chown -R root:root ~/.openclaw/credentials && sudo chmod 700 ~/.openclaw/credentials "
                "(macOS: root:wheel)")
    cred_dir = openclaw_dir() / "credentials"
    if not cred_dir.exists():
        f.passed = True
        f.detail = "No credentials directory found."
        return f
    perms  = file_perms(cred_dir)
    uid    = file_owner(cred_dir)
    issues = []
    if perms and perms not in ("0o700", "0o500"):
        issues.append("dir perms={} (need 700)".format(perms))
    if uid is not None and uid != 0:
        issues.append("owned by uid {} (need root)".format(uid))
    try:
        for child in cred_dir.iterdir():
            cp = file_perms(child)
            if cp and int(cp, 8) & 0o044:
                issues.append("{} world/group readable ({})".format(child.name, cp))
    except PermissionError:
        pass
    if not issues:
        f.passed = True
        f.detail = "Credentials directory has restrictive permissions."
    else:
        f.detail = "; ".join(issues) + "."
    return f

def oc_check_audit_logs():
    """OC20: Audit log pipeline."""
    f = Finding(4, "OS/Secrets", "OC20", "Audit log pipeline", "MEDIUM", "",
                "Forward agent logs to a SIEM (Datadog, Splunk, Elastic). "
                "Expert required: xscaleai.com/consult")
    oc_dir    = openclaw_dir()
    indicators, has_fwd = [], False
    for loc in [oc_dir / "logs", oc_dir / "log",
                Path.home() / ".local" / "share" / "openclaw" / "logs"]:
        if loc.exists():
            indicators.append("logs at {}".format(loc))
            break
    if cmd_output("grep -rl 'openclaw' /etc/rsyslog.d/ 2>/dev/null"):
        has_fwd = True
        indicators.append("rsyslog forwarding configured")
    if cmd_output("systemctl list-units 2>/dev/null | grep -i openclaw"):
        has_fwd = True
        indicators.append("systemd unit (journald logging)")
    for agent_name, proc in [("Datadog", "datadog-agent"), ("Splunk", "splunkd"),
                               ("Elastic", "filebeat"), ("Fluentd", "fluentd"),
                               ("Vector", "vector")]:
        if cmd_output("pgrep -f {} 2>/dev/null".format(proc)):
            has_fwd = True
            indicators.append("{} agent running".format(agent_name))
    if has_fwd:
        f.passed = True
        f.detail = "Log forwarding: {}.".format("; ".join(indicators))
    else:
        f.detail = "No log forwarding detected. Audit trail is local-only or absent."
    return f

