def oc_check_multi_agent():
    """OC19: Multi-agent isolation."""
    f = Finding(2, "Operator", "OC19", "Multi-agent isolation", "MEDIUM", "",
                "Isolate agents in separate containers or VMs with distinct credential sets. "
                "Expert required: xscaleai.com/consult")
    agents = []
    oc_procs = cmd_output("pgrep -afc openclaw 2>/dev/null")
    if oc_procs:
        try:
            n = int(oc_procs.strip())
            if n > 1:
                agents.append("OpenClaw: {} processes".format(n))
        except ValueError:
            pass
    for name, pattern in [("NemoClaw", "nemoclaw"), ("Aider", "aider"), ("Cursor", "cursor")]:
        cnt = cmd_output("pgrep -fc '{}' 2>/dev/null".format(pattern))
        if cnt:
            try:
                n = int(cnt.strip())
                if n > 0:
                    agents.append("{}: {} process(es)".format(name, n))
            except ValueError:
                pass
    if len(agents) > 1:
        f.detail = "Multiple agent frameworks on this host: {}.".format("; ".join(agents))
    else:
        f.passed = True
        f.detail = "Single agent instance detected."
    return f

