def get_default_gateway():
    if PLATFORM == "linux":
        out = cmd_output("ip route show default 2>/dev/null | awk '/default/{print $3}'")
        return out.split("\n")[0].strip() if out else None
    elif PLATFORM == "macos":
        out = cmd_output("route -n get default 2>/dev/null | awk '/gateway:/{print $2}'")
        return out.strip() if out else None
    return None

def get_lan_devices():
    out = cmd_output("arp -a 2>/dev/null")
    if not out:
        return []
    ips = []
    for line in out.split("\n"):
        m = re.search(r'\((\d+\.\d+\.\d+\.\d+)\)', line)
        if m:
            ip = m.group(1)
            if not ip.endswith(".255") and ip != "0.0.0.0":
                ips.append(ip)
    return ips

def get_local_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return None

def detect_local_llm():
    found = []
    if probe_port("127.0.0.1", 11434):
        found.append(("Ollama", "localhost:11434"))
    elif cmd_output("pgrep -x ollama 2>/dev/null"):
        found.append(("Ollama", "process running"))
    for proc in ["llama-server", "llama.cpp", "llamafile"]:
        if cmd_output("pgrep -f {} 2>/dev/null".format(proc)):
            found.append((proc, "process running"))
            break
    if probe_port("127.0.0.1", 1234):
        found.append(("LM Studio", "localhost:1234"))
    if probe_port("127.0.0.1", 8000) and cmd_output("pgrep -f vllm 2>/dev/null"):
        found.append(("vLLM", "localhost:8000"))
    return found

