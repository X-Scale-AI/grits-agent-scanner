def format_terminal(findings, score, rating, source_label, agent_label, timestamp):
    lines_check = OC_LINES if agent_label == "OpenClaw" else NC_LINES
    lines = []
    lines.append("")
    lines.append("{}{}{}".format(C["BOLD"], "=" * 68, C["RESET"]))
    lines.append("{}  GRITS Agent Scanner  v{}  by X Scale AI{}".format(C["BOLD"], GRITS_VERSION, C["RESET"]))
    lines.append("=" * 68)
    lines.append("")
    lines.append("  {}WHAT THIS TOOL DOES{}".format(C["DIM"], C["RESET"]))
    lines.append("  {}Reads your config. Checks security. Reports findings.{}".format(C["DIM"], C["RESET"]))
    lines.append("  {}Nothing is modified. Ever.{}".format(C["DIM"], C["RESET"]))
    lines.append("")
    lines.append("  Platform  {}".format(PLATFORM.upper()))
    lines.append("  Agent     {}".format(agent_label))
    lines.append("  Config    {}".format(source_label))
    lines.append("  Scanned   {}".format(timestamp))
    lines.append("")
    lines.append("-" * 68)
    lines.append("")

    layers = {}
    for f in findings:
        key = "L{} -- {}".format(f.layer, f.layer_name.upper())
        layers.setdefault(key, []).append(f)

    for layer_key in sorted(layers.keys()):
        lines.append("  {}{}{}".format(C["BOLD"] + C["CYAN"], layer_key, C["RESET"]))
        for f in layers[layer_key]:
            entry = lines_check.get(f.check_id)
            if f.passed:
                msg  = entry[1] if entry else f.title
                icon = "{}[PASS]{}".format(C["GREEN"], C["RESET"])
            else:
                msg  = entry[0] if entry else f.detail
                icon = "{}[FAIL]{}".format(C["RED"], C["RESET"])
            lines.append("  {}  {}{}  {}{}".format(
                icon, C["DIM"], f.check_id, C["RESET"], msg))
        lines.append("")

    fail_count = sum(1 for f in findings if not f.passed)
    pass_count = len(findings) - fail_count
    lines.append("-" * 68)
    lines.append("")
    lines.append("  SCORE   {}/{}   {}   {}%  {}{}{}".format(
        pass_count, len(findings), score_bar(score), score,
        C["BOLD"], rating.upper(), C["RESET"]))
    lines.append("")

    if fail_count > 0:
        fixable = [f for f in findings if not f.passed
                   and (OC_LINES.get(f.check_id) or NC_LINES.get(f.check_id, (None, None, False)))[2] == True]
        expert  = [f for f in findings if not f.passed
                   and (OC_LINES.get(f.check_id) or NC_LINES.get(f.check_id, (None, None, False)))[2] != True]

        if fixable:
            lines.append("  {}AUTO-FIXABLE NOW ({} issue{}){}".format(
                C["YELLOW"], len(fixable), "s" if len(fixable) != 1 else "", C["RESET"]))
            lines.append("  Run:  {}./grits-agent-secure{}".format(C["BOLD"], C["RESET"]))
            lines.append("")
        if expert:
            lines.append("  {}NEEDS AN EXPERT ({} issue{}){}".format(
                C["RED"], len(expert), "s" if len(expert) != 1 else "", C["RESET"]))
            for f in expert:
                entry = lines_check.get(f.check_id)
                msg = entry[0] if entry else f.detail
                lines.append("  {}{}{}  {}{}".format(C["DIM"], f.check_id, C["RESET"], msg, ""))
            lines.append("")
            lines.append("  Schedule a free 30-min call:  {}{}{}".format(C["BOLD"], GRITS_CONSULT, C["RESET"]))
            lines.append("")

    lines.append("-" * 68)
    lines.append("  {}{}{}".format(C["DIM"], GRITS_BRAND, C["RESET"]))
    lines.append("  {}{}{}".format(C["DIM"], GRITS_REPO, C["RESET"]))
    lines.append("=" * 68)
    lines.append("")
    return "\n".join(lines)


def format_markdown(findings, score, rating, source_label, agent_label, timestamp):
    lines_check = OC_LINES if agent_label == "OpenClaw" else NC_LINES
    lines = []
    lines.append("# GRITS Agent Scanner -- {} Report".format(agent_label))
    lines.append("")
    lines.append("| | |")
    lines.append("|---|---|")
    lines.append("| **Scanned** | {} |".format(timestamp))
    lines.append("| **Agent** | {} |".format(agent_label))
    lines.append("| **Config** | {} |".format(source_label))
    lines.append("| **Score** | {}% -- {} |".format(score, rating))
    lines.append("")
    lines.append("## Findings")
    lines.append("")
    lines.append("| Layer | ID | Result | Implication |")
    lines.append("|---|---|---|---|")
    for f in findings:
        entry  = lines_check.get(f.check_id)
        status = "PASS" if f.passed else "FAIL"
        msg    = (entry[1] if f.passed else entry[0]) if entry else (f.title if f.passed else f.detail)
        lines.append("| L{} {} | {} | {} | {} |".format(f.layer, f.layer_name, f.check_id, status, msg))
    lines.append("")
    fail_count = sum(1 for f in findings if not f.passed)
    pass_count = len(findings) - fail_count
    lines.append("**{} passed, {} failed**".format(pass_count, fail_count))
    lines.append("")
    fixable = [f for f in findings if not f.passed
               and (OC_LINES.get(f.check_id) or NC_LINES.get(f.check_id, (None, None, False)))[2] == True]
    if fixable:
        lines.append("## Auto-fixable ({} issue{})".format(len(fixable), "s" if len(fixable) != 1 else ""))
        lines.append("")
        lines.append("```bash")
        lines.append("./grits-agent-secure")
        lines.append("```")
        lines.append("")
    lines.append("---")
    lines.append("")
    lines.append("*{}*".format(GRITS_BRAND))
    lines.append("*{}*".format(GRITS_REPO))
    return "\n".join(lines)


def format_json(findings, score, rating, source_label, agent_label, timestamp):
    return json.dumps({
        "grits_version": GRITS_VERSION,
        "timestamp": timestamp,
        "agent": agent_label,
        "config": source_label,
        "platform": PLATFORM,
        "score": score,
        "rating": rating,
        "pass_count": sum(1 for f in findings if f.passed),
        "fail_count": sum(1 for f in findings if not f.passed),
        "findings": [f.to_dict() for f in findings],
        "attribution": GRITS_BRAND,
        "repo": GRITS_REPO,
    }, indent=2)

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="GRITS Agent Scanner -- security posture for AI agents",
        epilog=GRITS_BRAND,
    )
    parser.add_argument("--agent", default="openclaw",
                        choices=["openclaw", "nemoclaw"],
                        help="Agent to scan (default: openclaw)")
    parser.add_argument("--config", help="Path to config/policy file")
    parser.add_argument("--report", action="store_true", help="Markdown output")
    parser.add_argument("--json",   action="store_true", help="JSON output")
    args = parser.parse_args()

    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    if args.agent == "openclaw":
        config_path   = find_openclaw_config(args.config)
        config        = None
        source_label  = str(config_path) if config_path else "NOT FOUND"
        if config_path:
            try:
                config = load_json5(config_path)
            except Exception:
                pass
        findings     = run_openclaw_checks(config_path, config)
        agent_label  = "OpenClaw"
    else:
        findings     = run_nemoclaw_checks(args.config)
        source_label = args.config or "auto-detected"
        agent_label  = "NVIDIA NemoClaw"

    score    = compute_score(findings)
    rating   = grade(score)

    if args.json:
        print(format_json(findings, score, rating, source_label, agent_label, timestamp))
    elif args.report:
        print(format_markdown(findings, score, rating, source_label, agent_label, timestamp))
    else:
        print(format_terminal(findings, score, rating, source_label, agent_label, timestamp))


if __name__ == "__main__":
    main()
