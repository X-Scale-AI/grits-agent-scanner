def oc_check_tool_profile(config):
    """OC06: Tool profile is not 'full'."""
    f = Finding(3, "Application", "OC06", "Tool profile", "HIGH", "",
                "Set tool profile to 'minimal' or 'standard'. Never use 'full' in production.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    tools = config.get("tools", config.get("toolConfig", {}))
    if not isinstance(tools, dict):
        f.passed = True
        f.detail = "No tools config found (defaults apply)."
        return f
    profile = tools.get("profile", tools.get("toolProfile", ""))
    if isinstance(profile, str) and profile.lower() in ("full", "unrestricted", "all", "*"):
        f.detail = "Tool profile set to '{}'. Agent has unrestricted tool access.".format(profile)
    else:
        f.passed = True
        f.detail = "Tool profile: '{}'.".format(profile or "default")
    return f

def oc_check_tool_deny(config):
    """OC07: Dangerous tools denied."""
    f = Finding(3, "Application", "OC07", "Tool deny list", "HIGH", "",
                "Add to deny list: file_write, code_execution, shell_exec, browser_navigate.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    tools = config.get("tools", config.get("toolConfig", {}))
    if not isinstance(tools, dict):
        f.detail = "No tools config found."
        return f
    deny = tools.get("deny", tools.get("denyList", tools.get("deny_list", [])))
    if not isinstance(deny, list):
        deny = []
    dangerous  = ["file_write", "code_execution", "shell_exec", "exec", "browser_navigate"]
    denied_bad = [d for d in dangerous if d in deny]
    if len(denied_bad) >= 2:
        f.passed = True
        f.detail = "Deny list includes: {}.".format(", ".join(denied_bad))
    elif deny:
        f.detail = "Deny list exists but missing key tools. Current: {}.".format(", ".join(deny))
    else:
        f.detail = "No tool deny list. Agent may access all tools."
    return f

def oc_check_exec_policy(config):
    """OC08: Exec/elevated execution restricted."""
    f = Finding(3, "Application", "OC08", "Exec/elevated policy", "CRITICAL", "",
                "Set execSecurity to 'restricted' or 'disabled'. Disable elevated unless scoped.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    tools   = config.get("tools", config.get("toolConfig", {}))
    if not isinstance(tools, dict):
        f.passed = True
        f.detail = "No exec policy set (defaults apply)."
        return f
    exec_sec = tools.get("execSecurity", tools.get("exec_security", tools.get("exec", "")))
    elevated = tools.get("elevated", tools.get("elevatedPolicy", tools.get("elevated_policy", "")))
    issues   = []
    if isinstance(exec_sec, str) and exec_sec.lower() in ("open", "unrestricted", "allow", "all", "enabled"):
        issues.append("execSecurity='{}'".format(exec_sec))
    if isinstance(elevated, str) and elevated.lower() in ("open", "unrestricted", "allow", "all", "enabled"):
        issues.append("elevated='{}'".format(elevated))
    if not issues:
        f.passed = True
        f.detail = "Exec: '{}', Elevated: '{}'.".format(exec_sec or "default", elevated or "default")
    else:
        f.detail = "Dangerous exec settings: {}.".format(", ".join(issues))
    return f

def oc_check_sandbox(config):
    """OC09: Sandbox mode enabled."""
    f = Finding(3, "Application", "OC09", "Sandbox mode", "HIGH", "",
                "Set agent.sandbox to true in your openclaw.json.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    agent   = config.get("agent", config.get("agentDefaults", config.get("agents", {}).get("defaults", {})))
    if not isinstance(agent, dict):
        agent = config
    sandbox = agent.get("sandbox", agent.get("sandboxMode", agent.get("sandbox_mode", None)))
    if sandbox is True or (isinstance(sandbox, str) and sandbox.lower() in ("true", "strict", "enabled")):
        f.passed = True
        f.detail = "Sandbox mode enabled."
    elif sandbox is False or (isinstance(sandbox, str) and sandbox.lower() in ("false", "disabled", "off")):
        f.detail = "Sandbox mode explicitly disabled. Agent has full host filesystem access."
    else:
        f.detail = "Sandbox mode not set. Check your OpenClaw version defaults."
    return f

def oc_check_plugins(config):
    """OC10: Plugin allowlist configured."""
    f = Finding(3, "Application", "OC10", "Plugin allowlist", "MEDIUM", "",
                "Set plugins.allow to an explicit list. Remove any wildcard entries.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    plugins = config.get("plugins", {})
    if not isinstance(plugins, dict):
        f.passed = True
        f.detail = "No plugins configured."
        return f
    allow = plugins.get("allow", None)
    if isinstance(allow, list) and len(allow) > 0:
        if "*" in allow or "all" in [str(a).lower() for a in allow]:
            f.detail = "Plugin allow list contains wildcard. All plugins permitted."
        else:
            f.passed = True
            f.detail = "{} plugin(s) explicitly allowed.".format(len(allow))
    else:
        f.detail = "No explicit plugin allowlist. Plugins may load without restriction."
    return f

