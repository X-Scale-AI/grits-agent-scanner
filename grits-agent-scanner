def oc_check_heartbeat(config):
    """OC14: Heartbeat routes to local/cheap model."""
    f = Finding(5, "Financial", "OC14", "Heartbeat model routing", "MEDIUM", "",
                "Configure heartbeat.model to a local Ollama model. "
                "See score/configs/openclaw.json.hardened.mac for example.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    agent     = config.get("agents", {}).get("defaults", config.get("agent",
                config.get("agentDefaults", config.get("defaults", {}))))
    if not isinstance(agent, dict):
        agent = config
    heartbeat = agent.get("heartbeat", None)
    local_llms = detect_local_llm()
    if heartbeat is not None:
        hb_str = str(heartbeat).lower()
        if any(ind in hb_str for ind in ["ollama", "local", "llama", "phi", "gemma", "tiny", "qwen"]):
            f.passed = True
            f.detail = "Heartbeat routed to local model: {}.".format(heartbeat)
            if local_llms:
                f.detail += " Confirmed running: {}.".format(", ".join(n for n, _ in local_llms))
            return f
        f.detail = "Heartbeat model '{}' may be a cloud model.".format(
            heartbeat if isinstance(heartbeat, str) else heartbeat.get("model", "unknown"))
        if local_llms:
            f.detail += " Local LLM available but unused: {}.".format(
                ", ".join(n for n, _ in local_llms))
        return f
    if local_llms:
        f.detail = "No heartbeat model set but local LLM detected: {}.".format(
            ", ".join(n for n, _ in local_llms))
    else:
        f.detail = "No heartbeat model configured. Primary (expensive) model used for pings."
    return f

def oc_check_spending(config):
    """OC15: Spending limits configured."""
    f = Finding(5, "Financial", "OC15", "Spending limits", "MEDIUM", "",
                "Set spending limits in your API provider dashboard. Disable auto-topup.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    agent = config.get("agents", {}).get("defaults",
            config.get("agent", config.get("agentDefaults", config.get("defaults", {}))))
    if not isinstance(agent, dict):
        agent = config
    details, has_limit = [], False
    for key in ["maxTokens", "max_tokens", "maxSpend", "max_spend", "budgetLimit",
                "budget_limit", "spendingLimit", "spending_limit", "maxContext", "max_context"]:
        val = agent.get(key)
        if val is not None:
            has_limit = True
            details.append("{}={}".format(key, val))
    auto_topup = agent.get("autoTopup", agent.get("auto_topup", None))
    if auto_topup is True or (isinstance(auto_topup, str) and auto_topup.lower() in ("true", "enabled", "on")):
        f.detail = "Auto-topup is enabled. No spending cap."
        return f
    if auto_topup is False or (isinstance(auto_topup, str) and auto_topup.lower() in ("false", "disabled", "off")):
        has_limit = True
        details.append("autoTopup=disabled")
    if has_limit:
        f.passed = True
        f.detail = "Cost controls: {}.".format(", ".join(details))
    else:
        f.detail = "No spending limits or cost controls found in config."
    return f

def oc_check_dangerous_flags(config):
    """OC16: No dangerous runtime flags."""
    f = Finding(5, "Financial", "OC16", "Dangerous flags", "HIGH", "",
                "Set dangerouslySkipPermissions, yolo, trustAll, autoApprove to false.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    dangerous_flags = [
        "dangerouslySkipPermissions", "dangerously_skip_permissions",
        "yolo", "yoloMode", "yolo_mode",
        "trustAll", "trust_all", "trustAllTools",
        "autoApprove", "auto_approve", "autoApproveAll",
        "noConfirm", "no_confirm",
    ]
    found = []
    def search(d, prefix=""):
        if not isinstance(d, dict):
            return
        for k, v in d.items():
            if k in dangerous_flags:
                if v is True or (isinstance(v, str) and v.lower() in ("true", "enabled", "on", "yes")):
                    found.append("{}{}={}".format(prefix, k, v))
            if isinstance(v, dict):
                search(v, prefix="{}.".format(k))
    search(config)
    if not found:
        f.passed = True
        f.detail = "No dangerous runtime flags detected."
    else:
        f.detail = "Dangerous flags enabled: {}.".format(", ".join(found))
    return f

