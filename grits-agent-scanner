class Finding:
    def __init__(self, layer, layer_name, check_id, title, severity, detail, recommendation):
        self.layer        = layer
        self.layer_name   = layer_name
        self.check_id     = check_id
        self.title        = title
        self.severity     = severity
        self.detail       = detail
        self.recommendation = recommendation
        self.passed       = False

    def to_dict(self):
        return {
            "layer": self.layer, "layer_name": self.layer_name,
            "check_id": self.check_id, "title": self.title,
            "severity": self.severity, "detail": self.detail,
            "recommendation": self.recommendation, "passed": self.passed,
        }

