def oc_check_firewall():
    """OC01: Host firewall active (OS-aware)."""
    if PLATFORM == "macos":
        return _oc_firewall_macos()
    return _oc_firewall_linux()

def _oc_firewall_linux():
    f = Finding(1, "Network", "OC01", "Host firewall active", "CRITICAL", "",
                "sudo ufw default deny outgoing && sudo ufw default deny incoming && "
                "sudo ufw allow out 443/tcp && sudo ufw allow out 53/udp && sudo ufw --force enable")
    if cmd_exists("ufw"):
        status = cmd_output("sudo ufw status 2>/dev/null || ufw status 2>/dev/null")
        if status and "Status: active" in status:
            f.passed = True
            f.detail = "UFW active{}.".format(" with deny policy" if "deny" in status.lower() else "")
            return f
        f.detail = "UFW installed but not active."
        return f
    ipt = cmd_output("iptables -L OUTPUT -n 2>/dev/null | head -5")
    if ipt and "DROP" in ipt:
        f.passed = True
        f.detail = "iptables OUTPUT chain has DROP policy."
        return f
    nft = cmd_output("nft list ruleset 2>/dev/null | head -10")
    if nft and "drop" in nft.lower():
        f.passed = True
        f.detail = "nftables ruleset has drop rules."
        return f
    f.detail = "No active firewall detected (UFW, iptables, or nftables)."
    return f

def _oc_firewall_macos():
    f = Finding(1, "Network", "OC01", "Host firewall active", "CRITICAL", "",
                "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate on && "
                "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setstealthmode on")
    passes, issues = [], []
    alf = cmd_output("/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null")
    if alf and "enabled" in alf.lower():
        passes.append("Application Firewall enabled")
        stealth = cmd_output("/usr/libexec/ApplicationFirewall/socketfilterfw --getstealthmode 2>/dev/null")
        if stealth and "enabled" in stealth.lower():
            passes.append("stealth mode on")
    else:
        issues.append("Application Firewall disabled")
    pf = cmd_output("pfctl -s info 2>/dev/null | head -3")
    if pf and "enabled" in pf.lower():
        passes.append("pf enabled")
    for app, proc in [("LuLu", "LuLu"), ("Little Snitch", "Little Snitch")]:
        if cmd_output("pgrep -f '{}' 2>/dev/null".format(proc)):
            passes.append("{} running".format(app))
    if passes and not any("disabled" in i.lower() for i in issues):
        f.passed = True
        f.detail = "; ".join(passes) + "."
    else:
        f.detail = "No active firewall. " + "; ".join(issues) + "."
    return f

def oc_check_gateway_auth(config):
    """OC02: Gateway requires authentication."""
    f = Finding(1, "Network", "OC02", "Gateway authentication", "HIGH", "",
                "Set gateway.auth.mode to 'token' with a strong random token.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    gw = config.get("gateway", {})
    auth = gw.get("auth", "")
    if auth and auth not in ("", "none", "false", "disabled"):
        f.passed = True
        f.detail = "Gateway auth configured."
    else:
        bind = gw.get("bind", "127.0.0.1")
        if bind in ("0.0.0.0", "::"):
            f.severity = "CRITICAL"
            f.detail = "Gateway bound to {} with no auth. Anyone on the network can command your agent.".format(bind)
        else:
            f.detail = "Gateway auth not set. Bound to {} (localhost only mitigates but does not fix).".format(bind)
    return f

def oc_check_gateway_bind(config):
    """OC03: Gateway not bound to all interfaces."""
    f = Finding(1, "Network", "OC03", "Gateway bind address", "HIGH", "",
                "Set gateway.bind to 'loopback' or '127.0.0.1'. Never bind to 0.0.0.0.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    bind = config.get("gateway", {}).get("bind", "127.0.0.1")
    if bind in ("0.0.0.0", "::", ""):
        f.detail = "Gateway bound to {} (all interfaces). Exposed to LAN/WAN.".format(bind)
    else:
        f.passed = True
        f.detail = "Gateway bound to {}.".format(bind)
    return f

def oc_check_lan_exposure():
    """OC18: LAN network segmentation."""
    f = Finding(1, "Network", "OC18", "LAN network segmentation", "HIGH", "",
                "Isolate the agent host on a dedicated VLAN or subnet. "
                "Expert required: xscaleai.com/consult")
    gateway    = get_default_gateway()
    lan_devs   = get_lan_devices()
    local_ip   = get_local_ip()
    details    = []
    if gateway:
        if probe_port(gateway, 80, timeout=1) or probe_port(gateway, 443, timeout=1):
            details.append("gateway {} reachable".format(gateway))
        else:
            details.append("gateway: {}".format(gateway))
    if lan_devs:
        others = [ip for ip in lan_devs if ip != gateway]
        if others:
            details.append("{} device(s) visible on LAN".format(len(others)))
    if local_ip:
        octets = local_ip.split(".")
        if len(octets) == 4:
            prefix = ".".join(octets[:3])
            for t in [prefix + ".1", prefix + ".254"]:
                if t != local_ip and t != gateway:
                    if probe_port(t, 80, timeout=1) or probe_port(t, 22, timeout=1):
                        details.append("LAN services reachable at {}".format(t))
    if gateway:
        svc_hits = []
        for port, svc in [(22, "SSH"), (445, "SMB"), (548, "AFP"), (3389, "RDP"),
                          (5000, "NAS"), (9090, "Prometheus")]:
            if probe_port(gateway, port, timeout=1):
                svc_hits.append("{}({})".format(port, svc))
        if svc_hits:
            details.append("gateway services: {}".format(", ".join(svc_hits)))
    if not details:
        f.passed = True
        f.detail = "No LAN exposure detected."
    else:
        f.detail = "Unrestricted LAN access -- {}. Compromised agent can reach {} device(s).".format(
            "; ".join(details), len(lan_devs))
    return f

