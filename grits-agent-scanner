def oc_check_dm_policy(config):
    """OC04: DM policy is restrictive."""
    f = Finding(2, "Operator", "OC04", "DM policy", "CRITICAL", "",
                "Set dmPolicy to 'allowlist' and define allowFrom for every channel.")
    if config is None:
        f.detail = "Config not loaded."
        return f
    channels = config.get("channels", config.get("channel", {}))
    if not isinstance(channels, dict):
        f.detail = "No channels configured."
        return f
    open_ch = []
    for name, ch in channels.items():
        if not isinstance(ch, dict):
            continue
        dm = ch.get("dmPolicy", ch.get("dm_policy", ""))
        if isinstance(dm, str) and dm.lower() in ("open", "all", "any", "permissive", "*"):
            open_ch.append(name)
        allow_from = ch.get("allowFrom", ch.get("allow_from", None))
        if allow_from is None and dm.lower() not in ("disabled", "off", "none", "allowlist", "pairing"):
            open_ch.append("{} (no allowFrom)".format(name))
    open_ch = list(dict.fromkeys(open_ch))
    if not open_ch:
        f.passed = True
        f.detail = "All channels have restrictive DM policies."
    else:
        f.detail = "Open/permissive channels: {}.".format(", ".join(open_ch))
    return f

