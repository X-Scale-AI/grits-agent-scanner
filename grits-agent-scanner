def detect_platform():
    s = platform.system().lower()
    if s == "linux":
        return "linux"
    elif s == "darwin":
        return "macos"
    return "other"

PLATFORM = detect_platform()

# ---------------------------------------------------------------------------
# Shell helpers
# ---------------------------------------------------------------------------

def cmd_exists(name):
    return os.system("which {} > /dev/null 2>&1".format(name)) == 0

def cmd_output(cmd):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=10)
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None

def probe_port(host, port, timeout=2):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(timeout)
        result = s.connect_ex((host, port))
        s.close()
        return result == 0
    except Exception:
        return False

def file_perms(path):
    try:
        return oct(stat.S_IMODE(os.stat(path).st_mode))
    except Exception:
        return None

def file_owner(path):
    try:
        return os.stat(path).st_uid
    except Exception:
        return None

# ---------------------------------------------------------------------------
# JSON5 loader (comments, trailing commas, unquoted keys)
# ---------------------------------------------------------------------------

def load_json5(path):
    raw = Path(path).read_text(encoding="utf-8")
    try:
        import pyjson5
        return pyjson5.loads(raw)
    except ImportError:
        pass
    return _json5_fallback(raw)

def _json5_fallback(raw):
    text = re.sub(r'(?<!:)//.*?$', '', raw, flags=re.MULTILINE)
    text = re.sub(r'/\*.*?\*/', '', text, flags=re.DOTALL)
    text = re.sub(r',\s*([}\]])', r'\1', text)
    text = re.sub(r'(?<=[{,\n])\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*:', r' "\1":', text)
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return None

