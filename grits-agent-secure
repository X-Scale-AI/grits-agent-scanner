# ---------------------------------------------------------------------------
# OC12: Fix .env permissions
# ---------------------------------------------------------------------------

def fix_env_perms():
    fix = FixAction("OC12", "Fix .env file permissions",
                    "Sets .env to 600, owned by root. Does not change file contents.")
    oc_dir     = openclaw_dir()
    group      = "wheel" if PLATFORM == "macos" else "root"
    found_any  = False
    for env_path in [oc_dir / ".env", oc_dir / "secrets.env", Path.cwd() / ".env"]:
        if env_path.exists():
            found_any = True
            fix.add_cmd("sudo chown root:{} {}".format(group, env_path),
                        "Set {} owner to root:{}".format(env_path.name, group))
            fix.add_cmd("sudo chmod 600 {}".format(env_path),
                        "Set {} permissions to 600".format(env_path.name))
            if PLATFORM == "linux" and cmd_exists("restorecon"):
                fix.add_cmd("sudo restorecon -v {}".format(env_path),
                            "Restore SELinux context (RHEL/CentOS)")
    if not found_any:
        fix.skipped     = True
        fix.skip_reason = "No .env files found."
    return fix

# ---------------------------------------------------------------------------
# OC13: Fix credentials directory permissions
# ---------------------------------------------------------------------------

def fix_creds_perms():
    fix = FixAction("OC13", "Fix credentials directory permissions",
                    "Sets credentials dir to 700, owned by root. Does not change file contents.")
    cred_dir = openclaw_dir() / "credentials"
    group    = "wheel" if PLATFORM == "macos" else "root"
    if cred_dir.exists():
        fix.add_cmd("sudo chown -R root:{} {}".format(group, cred_dir),
                    "Set credentials dir owner to root:{} (recursive)".format(group))
        fix.add_cmd("sudo chmod 700 {}".format(cred_dir),
                    "Set credentials dir to 700 (owner only)")
        # Only chmod files if the directory is non-empty (glob fails on empty dirs)
        fix.add_cmd(
            "[ \"$(ls -A {})\" ] && sudo chmod 600 {}/* || true".format(cred_dir, cred_dir),
            "Set credential files to 600 (owner read/write only, skipped if empty)")
        if PLATFORM == "linux" and cmd_exists("restorecon"):
            fix.add_cmd("sudo restorecon -Rv {}".format(cred_dir),
                        "Restore SELinux context (RHEL/CentOS)")
    else:
        fix.skipped     = True
        fix.skip_reason = "No credentials directory found."
    return fix

# ---------------------------------------------------------------------------
# OC16: Disable dangerous flags
# ---------------------------------------------------------------------------

def fix_dangerous_flags(config):
    fix = FixAction("OC16", "Disable dangerous runtime flags",
                    "Sets dangerous flags to false. Does not remove them from config.")
    if config is None:
        fix.skipped     = True
        fix.skip_reason = "No config loaded."
        return fix
    dangerous_flags = [
        "dangerouslySkipPermissions", "dangerously_skip_permissions",
        "yolo", "yoloMode", "yolo_mode",
        "trustAll", "trust_all", "trustAllTools",
        "autoApprove", "auto_approve", "autoApproveAll",
        "noConfirm", "no_confirm",
    ]
    found = []
    def search(d, prefix=""):
        if not isinstance(d, dict):
            return
        for k, v in d.items():
            if k in dangerous_flags:
                if v is True or (isinstance(v, str) and v.lower() in ("true", "enabled", "on", "yes")):
                    found.append("{}{}".format(prefix, k))
                    fix.add_cfg("{}{}".format(prefix, k), False,
                                "Disable flag: {}".format(k))
            if isinstance(v, dict):
                search(v, prefix="{}.".format(k))
    search(config)
    if not found:
        fix.skipped     = True
        fix.skip_reason = "No dangerous flags found in config."
    return fix

# ---------------------------------------------------------------------------
# Config merger (non-destructive: only adds/appends, never deletes)
# ---------------------------------------------------------------------------

def merge_config(config, changes):
    if config is None:
        config = {}
    for key_path, (value, _) in changes.items():
        parts  = key_path.split(".")
        target = config
        for part in parts[:-1]:
            if part not in target or not isinstance(target[part], dict):
                target[part] = {}
            target = target[part]
        final  = parts[-1]
        if isinstance(value, list):
            existing = target.get(final, [])
            if not isinstance(existing, list):
                existing = []
            target[final] = existing + [v for v in value if v not in existing]
        else:
            target[final] = value
    return config

def write_config(config_path, config_dict):
    with open(config_path, "w", encoding="utf-8") as fh:
        json.dump(config_dict, fh, indent=2, ensure_ascii=False)
        fh.write("\n")

# ---------------------------------------------------------------------------
# Dynamic expert items -- run scanner and filter failing non-auto-fixable
# ---------------------------------------------------------------------------

# Which check IDs are auto-fixable (must stay in sync with grits-agent-scanner OC_LINES)
AUTO_FIXABLE_IDS = {"OC01", "OC07", "OC09", "OC12", "OC13", "OC16"}


def _print_expert_items(config_arg=None):
    """Run the scanner in JSON mode and print only failing non-auto-fixable items."""
    scanner = Path(__file__).parent / "grits-agent-scanner"
    cmd = [str(scanner), "--json"]
    if config_arg:
        cmd += ["--config", config_arg]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
        data   = json.loads(result.stdout)
        expert = [
            f for f in data.get("findings", [])
            if not f.get("passed") and f.get("check_id") not in AUTO_FIXABLE_IDS
        ]
    except Exception:
        expert = []

    # Filter out findings that couldn't be evaluated (no config)
    _config_noise = ("config not loaded", "no config file", "config not found")
    expert = [f for f in expert
              if not any(s in (f.get("detail") or "").lower() for s in _config_noise)]

    if not expert:
        return

    print("  {}STILL NEEDS AN EXPERT{}".format(C["YELLOW"], C["RESET"]))
    for f in expert:
        msg = f.get("detail") or f.get("title", "")
        print("  {}{}{}  {}".format(C["DIM"], f.get("check_id", "?"), C["RESET"], msg))
    print("")
    print("  Schedule a free 30-min call:  {}{}{}".format(C["BOLD"], GRITS_CONSULT, C["RESET"]))


