class FixAction:
    def __init__(self, check_id, title, description):
        self.check_id    = check_id
        self.title       = title
        self.description = description
        self.commands    = []       # list of (cmd, explanation)
        self.config_changes = {}    # dot-key -> (value, explanation)
        self.skipped     = False
        self.skip_reason = ""
        self.applied     = False
        self.errors      = []

    def add_cmd(self, cmd, explanation):
        self.commands.append((cmd, explanation))

    def add_cfg(self, key_path, value, explanation):
        self.config_changes[key_path] = (value, explanation)

# ---------------------------------------------------------------------------
# OC01: Enable firewall (OS-aware)
# ---------------------------------------------------------------------------

def _firewall_already_active():
    """Return True if a firewall is already enabled on this platform."""
    if PLATFORM == "macos":
        alf = cmd_run_output("/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null")
        if alf and "enabled" in alf.lower():
            return True
        pf = cmd_run_output("pfctl -s info 2>/dev/null | head -3")
        if pf and "enabled" in pf.lower():
            return True
        if cmd_run_output("pgrep -f LuLu 2>/dev/null") or cmd_run_output("pgrep -f 'Little Snitch' 2>/dev/null"):
            return True
        return False
    elif PLATFORM == "linux":
        status = cmd_run_output("sudo ufw status 2>/dev/null || ufw status 2>/dev/null")
        if status and "Status: active" in status:
            return True
        fw = cmd_run_output("firewall-cmd --state 2>/dev/null")
        if fw and "running" in fw.lower():
            return True
        ipt = cmd_run_output("iptables -L OUTPUT -n 2>/dev/null | head -5")
        if ipt and "DROP" in ipt:
            return True
        nft = cmd_run_output("nft list ruleset 2>/dev/null | head -10")
        if nft and "drop" in nft.lower():
            return True
        return False
    return False


def fix_firewall(apply=False, skip_confirm=False):
    fix = FixAction("OC01", "Enable host firewall",
                    "Turns on the firewall. Adds default-deny policy and allows HTTPS/DNS outbound.")

    if _firewall_already_active():
        fix.skipped     = True
        fix.skip_reason = "Firewall already active. Nothing to do."
        return fix

    if PLATFORM == "linux":
        uses_ufw       = cmd_exists("ufw")
        uses_firewalld = cmd_exists("firewall-cmd")

        if uses_ufw:
            fix.add_cmd("sudo ufw default deny outgoing", "Default outbound: deny")
            fix.add_cmd("sudo ufw default deny incoming", "Default inbound: deny")
            fix.add_cmd("sudo ufw allow out 443/tcp",     "Allow HTTPS outbound")
            fix.add_cmd("sudo ufw allow out 53/udp",      "Allow DNS")
            _inject_ssh_rules_ufw(fix, apply, skip_confirm)
            if not fix.skipped:
                fix.add_cmd("sudo ufw --force enable", "Enable UFW")

        elif uses_firewalld:
            fix.add_cmd("sudo systemctl enable --now firewalld",
                        "Enable and start firewalld")
            fix.add_cmd("sudo firewall-cmd --set-default-zone=drop",
                        "Set default zone to drop (deny all inbound)")
            fix.add_cmd("sudo firewall-cmd --permanent --add-service=https",
                        "Allow HTTPS outbound")
            fix.add_cmd("sudo firewall-cmd --permanent --add-port=53/udp",
                        "Allow DNS outbound")
            _inject_ssh_rules_firewalld(fix, apply, skip_confirm)
            if not fix.skipped:
                fix.add_cmd("sudo firewall-cmd --reload", "Apply permanent rules")

        elif DISTRO == "rhel":
            fix.add_cmd("sudo dnf install -y firewalld", "Install firewalld")
            fix.add_cmd("sudo systemctl enable --now firewalld",
                        "Enable and start firewalld")
            fix.add_cmd("sudo firewall-cmd --set-default-zone=drop",
                        "Set default zone to drop")
            fix.add_cmd("sudo firewall-cmd --permanent --add-service=https",
                        "Allow HTTPS outbound")
            fix.add_cmd("sudo firewall-cmd --permanent --add-port=53/udp",
                        "Allow DNS outbound")
            _inject_ssh_rules_firewalld(fix, apply, skip_confirm)
            if not fix.skipped:
                fix.add_cmd("sudo firewall-cmd --reload", "Apply permanent rules")

        else:
            # Debian/Ubuntu without ufw pre-installed
            fix.add_cmd("sudo apt-get install -y ufw",    "Install UFW")
            fix.add_cmd("sudo ufw default deny outgoing", "Default outbound: deny")
            fix.add_cmd("sudo ufw default deny incoming", "Default inbound: deny")
            fix.add_cmd("sudo ufw allow out 443/tcp",     "Allow HTTPS outbound")
            fix.add_cmd("sudo ufw allow out 53/udp",      "Allow DNS")
            _inject_ssh_rules_ufw(fix, apply, skip_confirm)
            if not fix.skipped:
                fix.add_cmd("sudo ufw --force enable", "Enable UFW")

    elif PLATFORM == "macos":
        # macOS Application Firewall is inbound-app-based, not packet filter.
        # pf controls incoming connections per-app; SSH is not affected by enabling ALF.
        fix.add_cmd(
            "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate on",
            "Enable macOS Application Firewall")
        fix.add_cmd(
            "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setstealthmode on",
            "Enable stealth mode (ignore unsolicited probes)")

    else:
        fix.skipped     = True
        fix.skip_reason = "Unsupported platform for auto-fix."

    return fix


def _inject_ssh_rules_ufw(fix, apply, skip_confirm):
    """
    Prompt for SSH allowlist and inject ufw allow rules into fix before enable.
    Marks fix as skipped (cancelled) if user aborts.
    In preview mode, adds a descriptive placeholder so the user knows a prompt is coming.
    """
    if not apply:
        # Preview: show that a prompt will happen at apply time
        fix.add_cmd(
            "# [interactive prompt at apply time]",
            "Allow SSH inbound -- you will be asked for source IP/CIDR before this runs")
        return

    ssh_rules = prompt_ssh_allowlist(skip_confirm=skip_confirm)

    if ssh_rules is None:
        fix.skipped     = True
        fix.skip_reason = "SSH allowlist cancelled. Firewall not enabled to prevent lockout."
        return

    for cidr, port in ssh_rules:
        if cidr == "0.0.0.0/0":
            fix.add_cmd(
                "sudo ufw allow in to any port {} proto tcp".format(port),
                "Allow SSH from everywhere on port {}".format(port))
        else:
            fix.add_cmd(
                "sudo ufw allow in from {} to any port {} proto tcp".format(cidr, port),
                "Allow SSH from {} on port {}".format(cidr, port))


def _inject_ssh_rules_firewalld(fix, apply, skip_confirm):
    """
    Same as _inject_ssh_rules_ufw but generates firewall-cmd rich rules.
    """
    if not apply:
        fix.add_cmd(
            "# [interactive prompt at apply time]",
            "Allow SSH inbound -- you will be asked for source IP/CIDR before this runs")
        return

    ssh_rules = prompt_ssh_allowlist(skip_confirm=skip_confirm)

    if ssh_rules is None:
        fix.skipped     = True
        fix.skip_reason = "SSH allowlist cancelled. Firewall not enabled to prevent lockout."
        return

    if not ssh_rules:
        # User chose to skip SSH rule -- nothing to inject
        return

    for cidr, port in ssh_rules:
        if cidr == "0.0.0.0/0":
            fix.add_cmd(
                "sudo firewall-cmd --permanent --add-port={}/tcp".format(port),
                "Allow SSH from everywhere on port {}".format(port))
        else:
            fix.add_cmd(
                "sudo firewall-cmd --permanent --add-rich-rule="
                "'rule family=\"ipv4\" source address=\"{}\" "
                "port port=\"{}\" protocol=\"tcp\" accept'".format(cidr, port),
                "Allow SSH from {} on port {}".format(cidr, port))

