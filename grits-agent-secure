def create_backup(config_path):
    """Create a timestamped backup of the config file and surrounding secrets."""
    ts          = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    oc_dir      = openclaw_dir()
    backup_dir  = oc_dir / "grits-backups" / ts
    backed_up   = []
    errors      = []

    try:
        backup_dir.mkdir(parents=True, exist_ok=True)
    except Exception as e:
        return None, None, ["Could not create backup directory: {}".format(e)]

    # Backup main config
    if config_path and Path(config_path).exists():
        dst = backup_dir / "openclaw.json"
        try:
            shutil.copy2(config_path, dst)
            backed_up.append(str(config_path))
        except Exception as e:
            errors.append("config: {}".format(e))

    # Backup .env files
    for env_path in [oc_dir / ".env", oc_dir / "secrets.env", Path.cwd() / ".env"]:
        if env_path.exists():
            dst = backup_dir / env_path.name
            try:
                shutil.copy2(env_path, dst)
                backed_up.append(str(env_path))
            except Exception as e:
                errors.append("{}: {}".format(env_path.name, e))

    # Backup credentials dir (copy tree)
    cred_src = oc_dir / "credentials"
    if cred_src.exists():
        cred_dst = backup_dir / "credentials"
        try:
            shutil.copytree(cred_src, cred_dst)
            backed_up.append(str(cred_src))
        except Exception as e:
            errors.append("credentials: {}".format(e))

    return backup_dir, backed_up, errors

def rollback_command(backup_dir, config_path):
    """Return the shell command to roll back the config."""
    if backup_dir is None or config_path is None:
        return None
    src = backup_dir / "openclaw.json"
    return "cp {} {}".format(src, config_path)


def list_backups():
    """Return sorted list of (timestamp_str, backup_dir_path) tuples, newest first."""
    backups_root = openclaw_dir() / "grits-backups"
    if not backups_root.exists():
        return []
    entries = []
    for d in backups_root.iterdir():
        if d.is_dir() and (d / "openclaw.json").exists():
            entries.append((d.name, d))
    entries.sort(key=lambda x: x[0], reverse=True)
    return entries


def do_rollback(timestamp, config_path, skip_confirm):
    """Restore a backup. timestamp=None means most recent."""
    banner("ROLLBACK MODE")
    backups = list_backups()

    if not backups:
        print("  {}No backups found.{}".format(C["RED"], C["RESET"]))
        print("  Run ./grits-agent-secure --apply first to create a backup.")
        print("")
        return 1

    if timestamp:
        match = [(ts, d) for ts, d in backups if ts == timestamp]
        if not match:
            print("  {}Backup '{}' not found.{}".format(C["RED"], timestamp, C["RESET"]))
            print("")
            print("  Available backups:")
            for ts, d in backups:
                print("    {}".format(ts))
            print("")
            return 1
        ts, backup_dir = match[0]
    else:
        ts, backup_dir = backups[0]

    backup_config = backup_dir / "openclaw.json"
    target        = config_path or find_openclaw_config()

    print("  {}RESTORING BACKUP{}".format(C["CYAN"], C["RESET"]))
    print("  From:  {}".format(backup_config))
    print("  To:    {}".format(target or "NOT FOUND"))
    print("")

    if target is None:
        print("  {}No config file found to restore to.{}".format(C["RED"], C["RESET"]))
        return 1

    # Safety: backup current state before overwriting
    ts_now     = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    safety_dir = openclaw_dir() / "grits-backups" / "pre-rollback-{}".format(ts_now)
    try:
        safety_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(target, safety_dir / "openclaw.json")
        print("  {}Current config backed up to:{}".format(C["DIM"], C["RESET"]))
        print("  {}".format(safety_dir))
        print("")
    except Exception as e:
        print("  {}WARNING: could not back up current config: {}{}".format(C["YELLOW"], e, C["RESET"]))
        print("")

    if not skip_confirm:
        try:
            answer = input("  Restore this backup? [y/N]  ").strip().lower()
        except (KeyboardInterrupt, EOFError):
            print("")
            print("  Aborted.")
            return 0
        if answer not in ("y", "yes"):
            print("  Aborted. Nothing was changed.")
            return 0
        print("")

    try:
        shutil.copy2(backup_config, target)
        print("  {}Restored successfully.{}".format(C["GREEN"], C["RESET"]))
        print("")
        print("  Re-scan to verify:")
        print("  {}./grits-agent-scanner{}".format(C["BOLD"], C["RESET"]))
    except Exception as e:
        print("  {}ERROR: {}{}".format(C["RED"], e, C["RESET"]))
        return 1

    print("")
    print("-" * 68)
    print("  {}{}{}".format(C["DIM"], GRITS_BRAND, C["RESET"]))
    print("=" * 68)
    print("")
    return 0

