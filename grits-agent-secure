def print_trust_intro(fixes, config_path, backup_dir, backed_up):
    """Print what will change and what will not, plus rollback instructions."""
    print("  {}WHAT WILL CHANGE{}".format(C["YELLOW"], C["RESET"]))
    n = 1
    for fix in fixes:
        if not fix.skipped:
            print("  {}. [{}]  {}".format(n, fix.check_id, fix.title))
            n += 1
    print("")
    print("  {}WHAT WILL NOT BE TOUCHED{}".format(C["GREEN"], C["RESET"]))
    print("  - Existing firewall rules (only additive changes)")
    print("  - Tools you currently allow (deny list is appended, not replaced)")
    print("  - All other agent settings")
    print("  - File contents (permissions only for .env / credentials)")
    print("")

    if backup_dir:
        print("  {}BACKUP CREATED{}".format(C["CYAN"], C["RESET"]))
        for f in backed_up:
            print("  + {}".format(f))
        print("")
        if config_path:
            rb = rollback_command(backup_dir, config_path)
            print("  {}TO ROLL BACK AT ANY TIME:{}".format(C["BOLD"], C["RESET"]))
            print("  {}{}{}".format(C["CYAN"], rb, C["RESET"]))
        print("")
    else:
        print("  {}NOTE: No config found. Config-level fixes will be skipped.{}".format(
            C["DIM"], C["RESET"]))
        print("")

