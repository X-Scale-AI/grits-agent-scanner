# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

def detect_platform():
    s = platform.system().lower()
    if s == "linux":   return "linux"
    if s == "darwin":  return "macos"
    return "other"

PLATFORM = detect_platform()

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def cmd_exists(name):
    return os.system("which {} > /dev/null 2>&1".format(name)) == 0

def cmd_run(cmd, dry_run=True, sudo=False):
    """Run a command. In dry_run mode print it, do not execute."""
    if dry_run:
        return True, "DRY RUN"
    try:
        result = subprocess.run(
            cmd, shell=True, capture_output=True, text=True, timeout=60)
        if result.returncode == 0:
            return True, result.stdout.strip()
        else:
            return False, result.stderr.strip() or "exit {}".format(result.returncode)
    except Exception as e:
        return False, str(e)

def file_perms(path):
    try:
        return oct(stat.S_IMODE(os.stat(path).st_mode))
    except Exception:
        return None

def file_owner(path):
    try:
        return os.stat(path).st_uid
    except Exception:
        return None

# ---------------------------------------------------------------------------
# JSON5 loader
# ---------------------------------------------------------------------------

def load_json5(path):
    raw = Path(path).read_text(encoding="utf-8")
    try:
        import pyjson5
        return pyjson5.loads(raw)
    except ImportError:
        pass
    return _json5_fallback(raw)

def _json5_fallback(raw):
    text = re.sub(r'(?<!:)//.*?$', '', raw, flags=re.MULTILINE)
    text = re.sub(r'/\*.*?\*/', '', text, flags=re.DOTALL)
    text = re.sub(r',\s*([}\]])', r'\1', text)
    text = re.sub(r'(?<=[{,\n])\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*:', r' "\1":', text)
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return None

# ---------------------------------------------------------------------------
# Config discovery
# ---------------------------------------------------------------------------

def find_openclaw_config(custom_path=None):
    if custom_path:
        p = Path(custom_path)
        return p if p.exists() else None
    for c in [
        Path.home() / ".openclaw" / "openclaw.json",
        Path.home() / ".config" / "openclaw" / "openclaw.json",
        Path.cwd() / "openclaw.json",
        Path.cwd() / ".openclaw" / "openclaw.json",
    ]:
        if c.exists():
            return c
    return None

def openclaw_dir():
    return Path.home() / ".openclaw"

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------

def create_backup(config_path):
    """Create a timestamped backup of the config file and surrounding secrets."""
    ts          = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    oc_dir      = openclaw_dir()
    backup_dir  = oc_dir / "grits-backups" / ts
    backed_up   = []
    errors      = []

    try:
        backup_dir.mkdir(parents=True, exist_ok=True)
    except Exception as e:
        return None, None, ["Could not create backup directory: {}".format(e)]

    # Backup main config
    if config_path and Path(config_path).exists():
        dst = backup_dir / "openclaw.json"
        try:
            shutil.copy2(config_path, dst)
            backed_up.append(str(config_path))
        except Exception as e:
            errors.append("config: {}".format(e))

    # Backup .env files
    for env_path in [oc_dir / ".env", oc_dir / "secrets.env", Path.cwd() / ".env"]:
        if env_path.exists():
            dst = backup_dir / env_path.name
            try:
                shutil.copy2(env_path, dst)
                backed_up.append(str(env_path))
            except Exception as e:
                errors.append("{}: {}".format(env_path.name, e))

    # Backup credentials dir (copy tree)
    cred_src = oc_dir / "credentials"
    if cred_src.exists():
        cred_dst = backup_dir / "credentials"
        try:
            shutil.copytree(cred_src, cred_dst)
            backed_up.append(str(cred_src))
        except Exception as e:
            errors.append("credentials: {}".format(e))

    return backup_dir, backed_up, errors

def rollback_command(backup_dir, config_path):
    """Return the shell command to roll back the config."""
    if backup_dir is None or config_path is None:
        return None
    src = backup_dir / "openclaw.json"
    return "cp {} {}".format(src, config_path)

# ---------------------------------------------------------------------------
# Fix actions
# ---------------------------------------------------------------------------

class FixAction:
    def __init__(self, check_id, title, description):
        self.check_id    = check_id
        self.title       = title
        self.description = description
        self.commands    = []       # list of (cmd, explanation)
        self.config_changes = {}    # dot-key -> (value, explanation)
        self.skipped     = False
        self.skip_reason = ""
        self.applied     = False
        self.errors      = []

    def add_cmd(self, cmd, explanation):
        self.commands.append((cmd, explanation))

    def add_cfg(self, key_path, value, explanation):
        self.config_changes[key_path] = (value, explanation)

# ---------------------------------------------------------------------------
# OC01: Enable firewall (OS-aware)
# ---------------------------------------------------------------------------

def fix_firewall():
    fix = FixAction("OC01", "Enable host firewall",
                    "Turns on the firewall. Adds default-deny policy and allows HTTPS/DNS outbound.")

    if PLATFORM == "linux":
        if cmd_exists("ufw"):
            fix.add_cmd("sudo ufw default deny outgoing",  "Default outbound: deny")
            fix.add_cmd("sudo ufw default deny incoming",  "Default inbound: deny")
            fix.add_cmd("sudo ufw allow out 443/tcp",      "Allow HTTPS outbound")
            fix.add_cmd("sudo ufw allow out 53/udp",       "Allow DNS")
            fix.add_cmd("sudo ufw --force enable",         "Enable UFW")
        else:
            fix.add_cmd("sudo apt-get install -y ufw",         "Install UFW")
            fix.add_cmd("sudo ufw default deny outgoing",      "Default outbound: deny")
            fix.add_cmd("sudo ufw default deny incoming",      "Default inbound: deny")
            fix.add_cmd("sudo ufw allow out 443/tcp",          "Allow HTTPS outbound")
            fix.add_cmd("sudo ufw allow out 53/udp",           "Allow DNS")
            fix.add_cmd("sudo ufw --force enable",             "Enable UFW")

    elif PLATFORM == "macos":
        fix.add_cmd(
            "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate on",
            "Enable macOS Application Firewall")
        fix.add_cmd(
            "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setstealthmode on",
            "Enable stealth mode (ignore unsolicited probes)")

    else:
        fix.skipped     = True
        fix.skip_reason = "Unsupported platform for auto-fix."

    return fix

# ---------------------------------------------------------------------------
# OC07: Add dangerous tools to deny list
# ---------------------------------------------------------------------------

def fix_tool_deny():
    fix = FixAction("OC07", "Add dangerous tools to deny list",
                    "Appends to your existing deny list. Does not remove any tools you currently allow.")
    dangerous = ["file_write", "code_execution", "shell_exec", "browser_navigate"]
    fix.add_cfg("tools.deny", dangerous,
                "Append to deny list: {}".format(", ".join(dangerous)))
    return fix

# ---------------------------------------------------------------------------
# OC09: Enable sandbox mode
# ---------------------------------------------------------------------------

def fix_sandbox():
    fix = FixAction("OC09", "Enable sandbox mode",
                    "Sets agent.sandbox = true. Does not change any other agent settings.")
    fix.add_cfg("agent.sandbox", True, "Set agent.sandbox to true")
    return fix

# ---------------------------------------------------------------------------
# OC12: Fix .env permissions
# ---------------------------------------------------------------------------

def fix_env_perms():
    fix = FixAction("OC12", "Fix .env file permissions",
                    "Sets .env to 600, owned by root. Does not change file contents.")
    oc_dir     = openclaw_dir()
    group      = "wheel" if PLATFORM == "macos" else "root"
    found_any  = False
    for env_path in [oc_dir / ".env", oc_dir / "secrets.env", Path.cwd() / ".env"]:
        if env_path.exists():
            found_any = True
            fix.add_cmd("sudo chown root:{} {}".format(group, env_path),
                        "Set {} owner to root:{}".format(env_path.name, group))
            fix.add_cmd("sudo chmod 600 {}".format(env_path),
                        "Set {} permissions to 600".format(env_path.name))
    if not found_any:
        fix.skipped     = True
        fix.skip_reason = "No .env files found."
    return fix

# ---------------------------------------------------------------------------
# OC13: Fix credentials directory permissions
# ---------------------------------------------------------------------------

def fix_creds_perms():
    fix = FixAction("OC13", "Fix credentials directory permissions",
                    "Sets credentials dir to 700, owned by root. Does not change file contents.")
    cred_dir = openclaw_dir() / "credentials"
    group    = "wheel" if PLATFORM == "macos" else "root"
    if cred_dir.exists():
        fix.add_cmd("sudo chown -R root:{} {}".format(group, cred_dir),
                    "Set credentials dir owner to root:{} (recursive)".format(group))
        fix.add_cmd("sudo chmod 700 {}".format(cred_dir),
                    "Set credentials dir to 700 (owner only)")
        fix.add_cmd("sudo chmod 600 {}/*".format(cred_dir),
                    "Set credential files to 600 (owner read/write only)")
    else:
        fix.skipped     = True
        fix.skip_reason = "No credentials directory found."
    return fix

# ---------------------------------------------------------------------------
# OC16: Disable dangerous flags
# ---------------------------------------------------------------------------

def fix_dangerous_flags(config):
    fix = FixAction("OC16", "Disable dangerous runtime flags",
                    "Sets dangerous flags to false. Does not remove them from config.")
    if config is None:
        fix.skipped     = True
        fix.skip_reason = "No config loaded."
        return fix
    dangerous_flags = [
        "dangerouslySkipPermissions", "dangerously_skip_permissions",
        "yolo", "yoloMode", "yolo_mode",
        "trustAll", "trust_all", "trustAllTools",
        "autoApprove", "auto_approve", "autoApproveAll",
        "noConfirm", "no_confirm",
    ]
    found = []
    def search(d, prefix=""):
        if not isinstance(d, dict):
            return
        for k, v in d.items():
            if k in dangerous_flags:
                if v is True or (isinstance(v, str) and v.lower() in ("true", "enabled", "on", "yes")):
                    found.append("{}{}".format(prefix, k))
                    fix.add_cfg("{}{}".format(prefix, k), False,
                                "Disable flag: {}".format(k))
            if isinstance(v, dict):
                search(v, prefix="{}.".format(k))
    search(config)
    if not found:
        fix.skipped     = True
        fix.skip_reason = "No dangerous flags found in config."
    return fix

# ---------------------------------------------------------------------------
# Config merger (non-destructive: only adds/appends, never deletes)
# ---------------------------------------------------------------------------

def merge_config(config, changes):
    if config is None:
        config = {}
    for key_path, (value, _) in changes.items():
        parts  = key_path.split(".")
        target = config
        for part in parts[:-1]:
            if part not in target or not isinstance(target[part], dict):
                target[part] = {}
            target = target[part]
        final  = parts[-1]
        if isinstance(value, list):
            existing = target.get(final, [])
            if not isinstance(existing, list):
                existing = []
            target[final] = existing + [v for v in value if v not in existing]
        else:
            target[final] = value
    return config

def write_config(config_path, config_dict):
    with open(config_path, "w", encoding="utf-8") as fh:
        json.dump(config_dict, fh, indent=2, ensure_ascii=False)
        fh.write("\n")

