def cmd_exists(name):
    return os.system("which {} > /dev/null 2>&1".format(name)) == 0

def cmd_run_output(cmd):
    """Run a read-only command and return stdout, or None on failure."""
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=10)
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None

def cmd_run(cmd, dry_run=True, sudo=False):
    """Run a command. In dry_run mode print it, do not execute."""
    if dry_run:
        return True, "DRY RUN"
    try:
        result = subprocess.run(
            cmd, shell=True, capture_output=True, text=True, timeout=60)
        if result.returncode == 0:
            return True, result.stdout.strip()
        else:
            return False, result.stderr.strip() or "exit {}".format(result.returncode)
    except Exception as e:
        return False, str(e)

def file_perms(path):
    try:
        return oct(stat.S_IMODE(os.stat(path).st_mode))
    except Exception:
        return None

def file_owner(path):
    try:
        return os.stat(path).st_uid
    except Exception:
        return None

