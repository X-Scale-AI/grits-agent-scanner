def main():
    parser = argparse.ArgumentParser(
        description="GRITS Agent Secure -- hardens your OpenClaw config safely",
        epilog=GRITS_BRAND,
    )
    parser.add_argument("--config",       help="Path to openclaw.json")
    parser.add_argument("--apply",        action="store_true",
                        help="Apply fixes (default is preview only)")
    parser.add_argument("--rollback",     nargs="?", const="latest", metavar="TIMESTAMP",
                        help="Restore most recent backup, or a specific backup by timestamp")
    parser.add_argument("--list-backups", action="store_true",
                        help="List all available backups")
    parser.add_argument("--yes",          action="store_true",
                        help="Skip confirmation prompt (for CI/scripts)")
    args = parser.parse_args()

    apply     = args.apply
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # --list-backups
    if args.list_backups:
        banner("AVAILABLE BACKUPS")
        backups = list_backups()
        if not backups:
            print("  No backups found. Run ./grits-agent-secure --apply first.")
        else:
            print("  {}  {}".format("TIMESTAMP".ljust(20), "LOCATION"))
            print("  " + "-" * 64)
            for ts, d in backups:
                print("  {}  {}".format(ts.ljust(20), d))
            print("")
            print("  To restore:  ./grits-agent-secure --rollback")
            print("  Specific:    ./grits-agent-secure --rollback {}".format(backups[0][0]))
        print("")
        return

    # --rollback
    if args.rollback:
        ts = None if args.rollback == "latest" else args.rollback
        sys.exit(do_rollback(ts, args.config, args.yes))

    config_path  = find_openclaw_config(args.config)
    config       = None
    if config_path and config_path.exists():
        try:
            config = load_json5(config_path)
        except Exception:
            pass

    # Build fix list with placeholder for OC01 (no SSH prompt yet -- fires after confirm)
    fixes = [
        fix_firewall(apply=False, skip_confirm=args.yes),
        fix_tool_deny(config),
        fix_sandbox(config),
        fix_env_perms(),
        fix_creds_perms(),
        fix_dangerous_flags(config),
    ]

    active_fixes = [f for f in fixes if not f.skipped]

    if apply:
        banner("APPLYING FIXES -- Platform: {}".format(PLATFORM.upper()))
    else:
        banner("PREVIEW MODE -- Nothing will be changed")
        print("  {}Platform:{}  {}".format(C["DIM"], C["RESET"], PLATFORM.upper()))
        print("  {}Config:{}    {}".format(C["DIM"], C["RESET"],
              str(config_path) if config_path else "NOT FOUND"))
        print("  {}Scanned:{}   {}".format(C["DIM"], C["RESET"], timestamp))
        print("")
        print("  Run  {}./grits-agent-secure --apply{}  to execute.".format(C["BOLD"], C["RESET"]))
        print("")
        print("-" * 68)
        print("")

    # Create backup before any changes
    backup_dir, backed_up, backup_errors = create_backup(config_path) if config_path else (None, [], [])
    if backup_errors:
        for err in backup_errors:
            print("  {}WARNING: backup issue -- {}{}".format(C["YELLOW"], err, C["RESET"]))
        print("")

    # Show trust intro
    print_trust_intro(fixes, config_path, backup_dir, backed_up)

    # In preview mode, stop here
    if not apply:
        # Show detailed preview
        print("  {}FIXES THAT WOULD BE APPLIED{}".format(C["BOLD"], C["RESET"]))
        print("")
        for fix in fixes:
            status = "{}SKIP{}  ".format(C["DIM"], C["RESET"]) if fix.skipped else "{}APPLY{} ".format(C["YELLOW"], C["RESET"])
            print("  {}  [{}]  {}".format(status, fix.check_id, fix.title))
            if fix.skipped:
                print("         {}{}{}".format(C["DIM"], fix.skip_reason, C["RESET"]))
            else:
                print("         {}{}{}".format(C["DIM"], fix.description, C["RESET"]))
                for cmd, explanation in fix.commands:
                    print("         > {}".format(explanation))
                    print("           {}{}{}".format(C["DIM"], cmd, C["RESET"]))
                for key_path, (value, explanation) in fix.config_changes.items():
                    print("         > {} -> {}".format(key_path, value))
            print("")
        print("-" * 68)
        print("  {}{}{}".format(C["DIM"], GRITS_BRAND, C["RESET"]))
        print("=" * 68)
        print("")
        return

    # Confirm
    if not args.yes:
        print("-" * 68)
        print("")
        try:
            answer = input("  Proceed? [y/N]  ").strip().lower()
        except (KeyboardInterrupt, EOFError):
            print("")
            print("  Aborted.")
            return
        if answer not in ("y", "yes"):
            print("  Aborted. Nothing was changed.")
            if backup_dir:
                print("  Backup preserved at: {}".format(backup_dir))
            return
        print("")

    # Re-build OC01 now with the real SSH prompt -- user has context and has confirmed
    fixes[0] = fix_firewall(apply=apply, skip_confirm=args.yes)

    # Apply
    print("-" * 68)
    print("")
    all_config_changes = {}
    applied_count      = 0
    skipped_count      = 0

    for fix in fixes:
        print("  {}[{}]{}  {}".format(C["BOLD"], fix.check_id, C["RESET"], fix.title))

        if fix.skipped:
            print("  {}SKIPPED: {}{}".format(C["DIM"], fix.skip_reason, C["RESET"]))
            print("")
            skipped_count += 1
            continue

        # Shell commands
        for cmd, explanation in fix.commands:
            print("  > {}".format(explanation))
            success, output = cmd_run(cmd, dry_run=False)
            if success:
                print("    {}OK{}".format(C["GREEN"], C["RESET"]))
            else:
                print("    {}FAILED: {}{}".format(C["RED"], output, C["RESET"]))
                fix.errors.append(output)
            print("")

        # Config changes (collect, apply after loop)
        for key_path, (value, explanation) in fix.config_changes.items():
            print("  > {} -> {}".format(key_path, value))
            all_config_changes[key_path] = (value, explanation)
            print("")

        applied_count += 1

    # Write config changes
    if all_config_changes and config_path and config:
        print("  {}Writing config changes...{}".format(C["CYAN"], C["RESET"]))
        config = merge_config(config, all_config_changes)
        try:
            write_config(config_path, config)
            print("  {}Config updated: {}{}".format(C["GREEN"], config_path, C["RESET"]))
        except Exception as e:
            print("  {}ERROR writing config: {}{}".format(C["RED"], e, C["RESET"]))
    elif all_config_changes and not config_path:
        print("  {}Config not found -- config-level changes were skipped.{}".format(
            C["YELLOW"], C["RESET"]))

    print("")
    print("-" * 68)
    print("")

    # Summary
    print("  {}DONE: {} fix(es) applied, {} skipped{}".format(
        C["GREEN"], applied_count, skipped_count, C["RESET"]))
    print("")

    if backup_dir and config_path:
        rb = rollback_command(backup_dir, config_path)
        print("  {}TO ROLL BACK:{}".format(C["BOLD"], C["RESET"]))
        print("  {}{}{}".format(C["CYAN"], rb, C["RESET"]))
        print("")

    print("  RE-SCAN TO VERIFY YOUR NEW SCORE:")
    print("  {}./grits-agent-scanner{}".format(C["BOLD"], C["RESET"]))
    print("")

    # What still needs an expert -- run scanner to get current state
    _print_expert_items(args.config if args.config else None)
    print("")
    print("-" * 68)
    print("  {}{}{}".format(C["DIM"], GRITS_BRAND, C["RESET"]))
    print("  {}{}{}".format(C["DIM"], GRITS_REPO, C["RESET"]))
    print("=" * 68)
    print("")


if __name__ == "__main__":
    main()
